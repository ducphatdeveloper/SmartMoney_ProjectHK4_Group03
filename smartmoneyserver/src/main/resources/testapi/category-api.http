### 29. Ghi lại wallet balance trước khi DELETE_ALL (Để verify hoàn tiền)
GET http://localhost:9999/api/wallets/{{test_wallet_id}}
Authorization: Bearer {{auth_token}}

> {%
    if (response.status === 200) {
        client.global.set("wallet_balance_before_delete", response.body.data.balance);
        client.log("💰 Số dư ví TRƯỚC xóa: " + response.body.data.balance);
    }
%}

### 30. XÓA danh mục với actionType=DELETE_ALL (Hoàn tiền + Xóa giao dịch)
# Expected: 200 OK - Giao dịch bị xóa, wallet balance được hoàn tiền
DELETE http://localhost:9999/api/categories/{{delete_all_category_id}}?actionType=DELETE_ALL
Authorization: Bearer {{auth_token}}

> {%
    client.test("DELETE_ALL - Status 200", function() {
        client.assert(response.status === 200, "Phải trả về 200 OK");
    });
    client.test("DELETE_ALL - Message thành công", function() {
        client.assert(response.body.success === true, "success phải là true");
        client.assert(response.body.message.includes("thành công"), "Message phải chứa 'thành công'");
    });
    client.log("✅ Xóa danh mục + giao dịch thành công");
%}

### 31. Verify wallet balance sau khi DELETE_ALL (Phải hoàn tiền)
GET http://localhost:9999/api/wallets/{{test_wallet_id}}
Authorization: Bearer {{auth_token}}

> {%
    if (response.status === 200) {
        client.global.set("wallet_balance_after_delete", response.body.data.balance);
        client.log("💰 Số dư ví SAU xóa: " + response.body.data.balance);
        client.test("DELETE_ALL - Hoàn tiền đúng", function() {
            // Nếu giao dịch là chi (ctgType=false) thì balance phải tăng 100000
            // Nếu giao dịch là thu (ctgType=true) thì balance phải giảm 100000
            // Trong test case này: giao dịch chi nên balance = before + 100000
            let beforeBalance = client.global.get("wallet_balance_before_delete");
            let afterBalance = response.body.data.balance;
            let expectedBalance = beforeBalance + 100000;
            client.assert(afterBalance === expectedBalance,
                         "Balance phải hoàn tiền chính xác: " + expectedBalance + " (thực tế: " + afterBalance + ")");
            client.log("✅ Hoàn tiền: " + beforeBalance + " → " + afterBalance + " (cộng 100000)");
        });
    }
%}

