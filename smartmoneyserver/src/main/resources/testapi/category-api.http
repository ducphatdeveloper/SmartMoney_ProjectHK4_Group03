### 25. XÓA danh mục có giao dịch (Không có actionType - Should FAIL)
# Expected: 400 Lỗi - "Danh mục này có X giao dịch. Vui lòng chọn hành động: MERGE hoặc DELETE_ALL"
DELETE http://localhost:9999/api/categories/{{txn_category_id}}
Authorization: Bearer {{auth_token}}

> {%
    client.test("Xóa danh mục có giao dịch - Status 400", function() {
        client.assert(response.status === 400, "Phải trả về 400 Bad Request");
    });
    client.test("Xóa danh mục có giao dịch - Yêu cầu chọn hành động", function() {
        client.assert(response.body.message.includes("giao dịch"), "Message phải chứa 'giao dịch'");
        client.assert(response.body.message.includes("MERGE") || response.body.message.includes("DELETE_ALL"), "Message phải chứa hành động");
    });
%}

